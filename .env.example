NODE_ENV=development
PORT=3000
DATABASE_URL=postgresql://app:local_password@localhost:5432/minki?schema=public
CORS_ORIGIN=http://localhost:3000
LOG_LEVEL=debug

ALLOWED_EMAIL_DOMAINS=example.ac.kr
ACCESS_TOKEN_SECRET=replace_with_local_access_token_secret
ACCESS_TOKEN_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=replace_with_local_refresh_token_secret
REFRESH_TOKEN_EXPIRES_IN=30d
EMAIL_VERIFICATION_EXPIRES_IN=10m

SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

AI_SERVICE_URL=
AI_SERVICE_API_KEY=
AI_SERVICE_TIMEOUT_MS=90000

APP_PORT=3000
POSTGRES_USER=app
POSTGRES_PASSWORD=local_password
POSTGRES_DB=minki
